{
  "name": "owl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/server/index.ts & vite",
    "build": "vite build",
    "start": "bun run src/server/index.ts",
    "typecheck": "tsgo --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "oxfmt --check && oxlint && tsgo --noEmit",
    "fix": "oxfmt && oxlint --fix"
  },
  "dependencies": {
    "@pierre/diffs": "1.2.11",
    "@pierre/icons": "0.6.1",
    "@pierre/theme": "1.0.3",
    "@pierre/theming": "0.0.1",
    "@pierre/trees": "1.0.0-beta.4",
    "hono": "4.11.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "2.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260623.1",
    "@vitejs/plugin-react": "5.1.1",
    "babel-plugin-react-compiler": "1.0.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "typescript": "5.9.2",
    "vite": "7.1.11"
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  },
  "trustedDependencies": [
    "esbuild"
  ]
}
